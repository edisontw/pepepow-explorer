MONITOR_READ_TIMEOUT_SECONDS=2
MONITOR_RPC_MAX_CONNECTIONS=2
MONITOR_RPC_MAX_KEEPALIVE_CONNECTIONS=1

MONITOR_RPC_FAIL_THRESHOLD=3

[Unit]
Description=PEPEPOW monitor sidecar
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=ubuntu
WorkingDirectory=/home/ubuntu/explorer
EnvironmentFile=-/home/ubuntu/explorer/monitor/.env
ExecStart=/home/ubuntu/explorer/monitor/.venv/bin/uvicorn monitor.app:app --host 127.0.0.1 --port 8010
Restart=on-failure
RestartSec=3

[Install]
WantedBy=multi-user.target
